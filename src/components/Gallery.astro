---
import { venue } from "../data/content";
---

<div class="gallery">
  {
    venue.gallery.map((item, i) => (
      <figure class={`gallery__item gallery__item--${i + 1} reveal-up`}>
        <div class="gallery__frame">
          <img src={item.src} alt={item.alt} loading="lazy" />
        </div>
        <div class="gallery__overlay" />
        <figcaption class="gallery__caption">{item.caption}</figcaption>
      </figure>
    ))
  }
</div>

<style>
  .gallery {
    columns: 2;
    column-gap: 1rem;
  }

  @media (min-width: 640px) {
    .gallery {
      column-gap: 1.25rem;
    }
  }

  .gallery__item {
    position: relative;
    margin-bottom: 1rem;
    break-inside: avoid;
    overflow: hidden;
    border-radius: 1rem;
  }

  .gallery__frame {
    width: 100%;
    overflow: hidden;
  }

  .gallery__frame img {
    display: block;
    height: 100%;
    width: 100%;
    object-fit: cover;
    transition: transform 0.7s;
  }

  /* Varied aspect ratios create the magazine-style masonry rhythm. */
  .gallery__item--1 .gallery__frame {
    aspect-ratio: 3 / 4;
  }
  .gallery__item--2 .gallery__frame {
    aspect-ratio: 4 / 3;
  }
  .gallery__item--3 .gallery__frame {
    aspect-ratio: 4 / 3;
  }
  .gallery__item--4 .gallery__frame {
    aspect-ratio: 3 / 4;
  }

  .gallery__item:hover .gallery__frame img {
    transform: scale(1.05);
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(var(--rgb-ink), 0.8), rgba(var(--rgb-ink), 0), transparent);
  }

  .gallery__caption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: white;
  }

  @media (min-width: 640px) {
    .gallery__caption {
      padding: 1.25rem;
      font-size: 0.875rem;
    }
  }
</style>
