---
interface Props {
  size?: string;
  class?: string;
}
const { size = "1.25rem", class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="currentColor"
  class={`star-icon ${className}`}
  style={`width:${size};height:${size};`}
  aria-hidden="true"
>
  <path d="M12 2l2.2 6.8L21 11l-6.8 2.2L12 20l-2.2-6.8L3 11l6.8-2.2L12 2z" />
</svg>

<style>
  .star-icon {
    flex-shrink: 0;
  }
</style>
