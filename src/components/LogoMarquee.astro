---
import { Image } from "astro:assets";
import { sponsorLogos, hero } from "../data/content";

const loop = [...sponsorLogos, ...sponsorLogos];

// Logos display at ≤68px tall inside the marquee box; 136px covers 2x
// displays. Astro resizes + converts to webp at build time (SVGs pass
// through untouched).
const LOGO_HEIGHT = 136;
---

<div class="marquee">
  <p class="marquee__label">
    {hero.patrociniLabel}
  </p>
  <div class="marquee__viewport">
    <div class="marquee-track marquee__track">
      {
        loop.map((logo) => (
          <div class="marquee__logo">
            <Image src={logo.image} alt={logo.alt} height={LOGO_HEIGHT} loading="lazy" />
          </div>
        ))
      }
    </div>
  </div>

  <a href="#sponsor" class="marquee__cta">
    Scopri tutti gli sponsor
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m0 0l-6-6m6 6l6-6" />
    </svg>
  </a>
</div>

<style>
  .marquee {
    width: 100%;
    overflow: hidden;
  }

  .marquee__label {
    margin-bottom: 1.25rem;
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(var(--rgb-white), 0.6);
  }

  @media (min-width: 640px) {
    .marquee__label {
      font-size: 0.75rem;
    }
  }

  .marquee__viewport {
    position: relative;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .marquee__track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .marquee__track {
      gap: 3.5rem;
    }
  }

  .marquee__logo {
    display: flex;
    flex-shrink: 0;
    height: 4.5rem;
    width: 9.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background-color: white;
    padding: 0.5rem 0.625rem;
  }

  @media (min-width: 640px) {
    .marquee__logo {
      height: 5.5rem;
      width: 11.5rem;
      padding: 0.625rem 0.875rem;
    }
  }

  /* :global() because the img is rendered by <Image> and doesn't carry this
     component's scope attribute. */
  .marquee__logo :global(img) {
    display: block;
    max-height: 100%;
    max-width: 100%;
    height: auto;
    width: auto;
    object-fit: contain;
    object-position: center;
    margin: 0 auto;
  }

  .marquee__cta {
    margin: 1.5rem auto 0;
    display: flex;
    width: fit-content;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(var(--rgb-white), 0.7);
    transition: color 0.2s;
  }

  .marquee__cta:hover,
  .marquee__cta:focus-visible {
    color: var(--color-sky-300);
  }

  .marquee__cta svg {
    height: 0.875rem;
    width: 0.875rem;
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .marquee__cta:hover svg,
  .marquee__cta:focus-visible svg {
    transform: translateY(2px);
  }
</style>
