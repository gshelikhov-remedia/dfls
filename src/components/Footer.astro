---
import { nav, contact, hero } from "../data/content";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="starfield"></div>
  <div class="site-footer__inner container">
    <div class="site-footer__grid">
      <div class="site-footer__col">
        <img src="/images/logo-white.svg" alt="Associazione Donne fra le Stelle" class="site-footer__logo" />
        <p class="site-footer__tagline">
          {hero.tagline}
        </p>
        <p class="site-footer__meta">
          {hero.location} · {hero.venue}
        </p>
      </div>

      <div class="site-footer__col">
        <h3>Sezioni</h3>
        <ul>
          {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
      </div>

      <div class="site-footer__col">
        <h3>Contatti</h3>
        <ul>
          <li><a href={`mailto:${contact.email}`}>{contact.email}</a></li>
          <li><a href={`tel:${contact.phone.replace(/\s+/g, "")}`}>{contact.phone}</a></li>
          <li><a href={`https://${contact.website}`}>{contact.website}</a></li>
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>© {year} Associazione Donne fra le Stelle. Tutti i diritti riservati.</p>
      <p>Voci di donne che accendono i sogni di tutti</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    background-color: var(--color-ink);
    color: rgba(var(--rgb-white), 0.7);
  }

  .site-footer__inner {
    position: relative;
    max-width: 80rem;
    padding-block: 4rem;
  }

  .site-footer__grid {
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .site-footer__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .site-footer__col {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .site-footer__logo {
    height: 7rem;
    width: auto;
    align-self: flex-start;
    margin-right: auto;
  }

  .site-footer__tagline {
    max-width: 20rem;
    font-size: 0.875rem;
    line-height: 1.625;
  }

  .site-footer__meta {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(var(--rgb-white), 0.4);
  }

  .site-footer__col h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: white;
  }

  .site-footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .site-footer__col a {
    transition: color 0.2s;
  }

  .site-footer__col a:hover {
    color: var(--color-sky-300);
  }

  .site-footer__bottom {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    border-top: 1px solid rgba(var(--rgb-white), 0.1);
    padding-top: 2rem;
    font-size: 0.75rem;
    color: rgba(var(--rgb-white), 0.4);
  }

  @media (min-width: 640px) {
    .site-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
