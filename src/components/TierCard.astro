---
import type { Tier } from "../data/content";
import StarIcon from "./StarIcon.astro";

interface Props {
  tier: Tier;
}
const { tier } = Astro.props;
---

<article class={`tier-card reveal-up ${tier.highlight ? "is-highlight" : ""}`}>
  {tier.highlight && <span class="tier-card__badge">Main</span>}

  <div class="tier-card__kicker">
    <StarIcon size="1.25rem" class={tier.highlight ? "is-light" : "is-muted"} />
    <span class="tier-card__subtitle">{tier.subtitle}</span>
  </div>

  <h3 class="tier-card__name">{tier.name}</h3>

  <p class="tier-card__price">{tier.price}</p>

  <ul class="tier-card__benefits">
    {
      tier.benefits.map((benefit) => (
        <li>
          <svg class="tier-card__check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
          </svg>
          <span>{benefit}</span>
        </li>
      ))
    }
  </ul>

  <a href="#contatti" data-tier={tier.name} class="tier-cta tier-card__cta">
    Richiedi informazioni
  </a>
</article>

<style>
  .tier-card {
    position: relative;
    display: flex;
    height: 100%;
    flex-direction: column;
    border-radius: 1.5rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    color: var(--color-primary-500);
    padding: 1.5rem;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
    transition: all 0.3s;
  }

  @media (min-width: 640px) {
    .tier-card {
      padding: 1.75rem;
    }
  }

  .tier-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 25px rgba(var(--rgb-black), 0.1);
  }

  .tier-card.is-highlight {
    border-color: rgba(var(--rgb-sky-400), 0.6);
    background: linear-gradient(to bottom, var(--color-deep-2), var(--color-ink));
    color: white;
    box-shadow: 0 25px 60px rgba(10, 15, 36, 0.35);
  }


  .tier-card__badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 9999px;
    background-color: var(--color-sky-400);
    padding: 0.25rem 1rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary-600);
    box-shadow: 0 1px 3px rgba(var(--rgb-black), 0.15);
  }

  .tier-card__kicker {
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tier-card__kicker :global(.is-light) {
    color: var(--color-sky-300);
  }
  .tier-card__kicker :global(.is-muted) {
    color: var(--color-sky-500);
  }

  .tier-card__subtitle {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary-600);
  }

  .is-highlight .tier-card__subtitle {
    color: var(--color-sky-300);
  }

  .tier-card__name {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--color-primary-600);
  }

  .is-highlight .tier-card__name {
    color: white;
  }

  @media (min-width: 640px) {
    .tier-card__name {
      font-size: 1.7rem;
    }
  }

  .tier-card__price {
    margin-top: 0.75rem;
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
  }

  .is-highlight .tier-card__price {
    color: var(--color-primary-50);
  }

  .tier-card__benefits {
    margin-top: 1.5rem;
    display: flex;
    flex: 1 1 0%;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tier-card__benefits li {
    display: flex;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.625;
  }

  .tier-card__benefits span {
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  .is-highlight .tier-card__benefits span {
    color: rgba(var(--rgb-white), 0.85);
  }

  .tier-card__check {
    margin-top: 0.125rem;
    height: 1rem;
    width: 1rem;
    flex-shrink: 0;
    color: var(--color-primary-500);
  }

  .is-highlight .tier-card__check {
    color: var(--color-sky-300);
  }

  .tier-card__cta {
    margin-top: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.2s;
    background-color: var(--color-primary-600);
    color: white;
  }

  .tier-card__cta:hover {
    transform: translateY(-2px);
    background-color: var(--color-primary-700);
  }

  .is-highlight .tier-card__cta {
    background-color: var(--color-sky-400);
    color: var(--color-primary-600);
  }

  .is-highlight .tier-card__cta:hover {
    background-color: var(--color-sky-300);
  }
</style>
