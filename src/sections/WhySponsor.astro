---

<section id="perche-sponsorizzare" class="why-sponsor">
  <div class="starfield"></div>
  <div class="why-sponsor__inner container">
    <SectionHeading eyebrow="I vantaggi" title={whySponsor.heading} dark />

    <div class="vantaggi-grid why-sponsor__grid">
      {
        whySponsor.reasons.map((reason, i) => (
          <div class="vantaggi-card why-sponsor__card">
            <div class="why-sponsor__icon icon-plain">
              {icons[i % icons.length].type === "fill" ? (
                <svg viewBox="0 0 640 640" fill="currentColor">
                  <path d={icons[i % icons.length].d} />
                </svg>
              ) : (
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                  <path stroke-linecap="round" stroke-linejoin="round" d={icons[i % icons.length].d} />
                </svg>
              )}
            </div>
            <h3>{reason.title}</h3>
            <p>{reason.text}</p>
          </div>
        ))
      }
    </div>

    <div class="why-sponsor__closing reveal-up">
      <p>{whySponsor.closing}</p>
      <Button href="#pacchetti" variant="primary">Scopri i pacchetti sponsor</Button>
    </div>
  </div>
</section>

<style>
  .why-sponsor {
    position: relative;
    overflow: hidden;
    background-color: var(--color-deep);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .why-sponsor {
      padding-block: 8rem;
    }
  }

  .why-sponsor__inner {
    position: relative;
    max-width: 72rem;
  }

  .why-sponsor__grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .why-sponsor__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .why-sponsor__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .why-sponsor__card {
    border-radius: 1rem;
    border: 1px solid rgba(var(--rgb-white), 0.1);
    background-color: rgba(var(--rgb-white), 0.04);
    padding: 1.5rem;
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
    transition: all 0.3s;
  }



  .why-sponsor__icon {
    margin-bottom: 1.25rem;
    color: var(--color-sky-300);
  }

  .why-sponsor__card h3 {
    font-family: var (--font-primary);
    font-size: 1.5rem;
    line-height: 1.1;
    color: white;
  }

  .why-sponsor__card p {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    line-height: 1.625;
    color: rgba(var(--rgb-white), 0.65);
  }

  .why-sponsor__closing {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .why-sponsor__closing p {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--color-sky-300);
  }

  @media (min-width: 640px) {
    .why-sponsor__closing p {
      font-size: 1.875rem;
    }
  }

  @media (min-width: 1024px) {
  .why-sponsor__card:nth-child(1),
  .why-sponsor__card:nth-child(4),
  .why-sponsor__card:nth-child(5) {
    grid-column: span 2;
  }
}
</style>
