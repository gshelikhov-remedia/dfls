---
import { festival, direttivo } from "../data/content";
import SectionHeading from "../components/SectionHeading.astro";
import StarIcon from "../components/StarIcon.astro";
---

<section id="festival" class="festival">
  <div class="festival__inner container">
    <SectionHeading eyebrow="Il Festival Donne fra le Stelle" title="Chi siamo" />

    <div class="festival__grid">
      <div class="festival__text reveal-up">
        {festival.paragraphs.map((p) => <p>{p}</p>)}
        <blockquote>
          {festival.highlight}
        </blockquote>
      </div>

      <div class="festival__awards reveal-up">
        <h3>{festival.awardsHeading}</h3>
        {
          festival.awards.map((award) => {
            const isRossella = award.name.includes("Rossella");
            const Wrapper = isRossella ? "a" : "div";
            return (
              <Wrapper
                class="festival__award-card"
                {...(isRossella ? { href: "/premio" } : {})}
              >
                <img
                  class="festival__award-image"
                  src={isRossella ? "/images/rosella.jpg" : "/images/logo-premio.jpg"}
                  alt={award.name}
                />
                <div class="festival__award-title">
                  <StarIcon size="1.25rem" />
                  <span>{award.name}</span>
                </div>
                <p>{award.description}</p>
                {isRossella && <span class="festival__award-link">Scopri il bando →</span>}
              </Wrapper>
            );
          })
        }
      </div>
    </div>

    <div class="direttivo reveal-up">
      <h3 class="direttivo__heading reveal-up">{direttivo.heading}</h3>
      <p class="direttivo__intro">{direttivo.intro}</p>

      <ul class="direttivo__list">
        {
          direttivo.members.map((member, i) => (
            <li class="direttivo__item">
              <button
                type="button"
                class="direttivo__row"
                aria-expanded="false"
                aria-controls={`direttivo-panel-${i}`}
                id={`direttivo-trigger-${i}`}
              >
                {member.photo ? (
                  <img class="direttivo__avatar" src={member.photo} alt={member.name} />
                ) : (
                  <span class="direttivo__avatar direttivo__avatar--placeholder" aria-hidden="true" />
                )}
                <span class="direttivo__meta">
                  <span class="direttivo__name">{member.name}</span>
                  <span class="direttivo__role">{member.role}</span>
                </span>
                <svg
                  class="direttivo__chevron"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M6 9l6 6 6-6"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </button>
              <div
                class="direttivo__panel"
                id={`direttivo-panel-${i}`}
                role="region"
                aria-labelledby={`direttivo-trigger-${i}`}
                hidden
              >
                <p>{member.bio}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .festival {
    position: relative;
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .festival {
      padding-block: 8rem;
    }
  }

  .festival__inner {
    max-width: 72rem;
  }

  .festival__grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .festival__grid {
      grid-template-columns: 1.3fr 1fr;
    }
  }

  .festival__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .festival__text p {
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (min-width: 640px) {
    .festival__text p {
      font-size: 1.125rem;
    }
  }

  .festival__text blockquote {
    margin-top: 1rem;
    border-left: 4px solid var(--color-sky-500);
    padding-left: 1.25rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.625;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .festival__text blockquote {
      font-size: 1.5rem;
    }
  }

  .festival__awards {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .festival__awards h3 {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .festival__awards h3 {
      font-size: 1.7rem;
    }
  }

  .festival__award-card {
    display: block;
    border-radius: 1rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    padding: 1.5rem;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
    transition: all 0.2s;
  }

  .festival__award-card:hover {
    box-shadow: 0 10px 15px rgba(var(--rgb-black), 0.1);
  }

  a.festival__award-card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--rgb-sky-400), 0.4);
  }

  .festival__award-link {
    margin-top: 0.75rem;
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-sky-600);
  }

  .festival__award-image {
    margin-bottom: 1rem;
    height: 4rem;
    width: 4rem;
    border-radius: 0.75rem;
    object-fit: cover;
  }

  .festival__award-title {
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-sky-500);
  }

  .festival__award-title span {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-primary-600);
  }

  .festival__award-card p {
    font-size: 0.875rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.7);
  }

  /* Direttivo */
  .direttivo {
    margin-top: 4rem;
    width: 100%;
  }

  .direttivo__heading {
    margin-bottom: 1.5rem;
    text-align: center;
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .direttivo__heading {
      font-size: 1.875rem;
    }
  }

  .direttivo__intro {
    margin-top: 0.75rem;
    text-align: center;
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (min-width: 640px) {
    .direttivo__intro {
      font-size: 1.125rem;
    }
  }

  .direttivo__list {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    gap: 1rem;
    list-style: none;
    padding: 0;
  }

  @media (min-width: 768px) {
    .direttivo__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .direttivo__item {
    border-radius: 1rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .direttivo__item:hover {
    box-shadow: 0 10px 15px rgba(var(--rgb-black), 0.1);
  }

  .direttivo__row {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
    border-radius: 1rem;
  }

  .direttivo__row:focus-visible {
    outline: 2px solid var(--color-sky-600);
    outline-offset: 2px;
  }

  .direttivo__avatar {
    flex-shrink: 0;
    height: 4rem;
    width: 4rem;
    border-radius: 9999px;
    object-fit: cover;
  }

  .direttivo__avatar--placeholder {
    display: block;
    background-color: var(--color-primary-100);
  }

  .direttivo__meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1 1 auto;
    min-width: 0;
  }

  .direttivo__name {
    font-family: var(--font-primary);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-primary-600);
  }

  .direttivo__role {
    font-size: 0.875rem;
    line-height: 1.4;
    color: rgba(var(--rgb-primary-600), 0.7);
  }

  .direttivo__chevron {
    flex-shrink: 0;
    color: var(--color-sky-500);
    transition: transform 0.25s ease;
  }

  .direttivo__row[aria-expanded="true"] .direttivo__chevron {
    transform: rotate(180deg);
  }

  .direttivo__panel {
    padding: 0 1.5rem 1.25rem calc(1.5rem + 4rem + 1rem);
  }

  .direttivo__panel p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (max-width: 600px) {
    .direttivo__panel {
      padding-left: 1.5rem;
    }
  }
</style>

<script>
  const rows = document.querySelectorAll<HTMLButtonElement>(".direttivo__row");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  rows.forEach((row) => {
    const panelId = row.getAttribute("aria-controls");
    const panel = panelId ? document.getElementById(panelId) : null;
    if (!panel) return;

    row.addEventListener("click", () => {
      const open = row.getAttribute("aria-expanded") === "true";
      row.setAttribute("aria-expanded", String(!open));

      if (open) {
        if (reduce) {
          panel.hidden = true;
          panel.style.height = "";
          return;
        }
        panel.style.height = panel.scrollHeight + "px";
        requestAnimationFrame(() => {
          panel.style.height = "0px";
        });
        panel.addEventListener(
          "transitionend",
          () => {
            panel.hidden = true;
            panel.style.height = "";
          },
          { once: true }
        );
      } else {
        panel.hidden = false;
        if (reduce) return;
        const target = panel.scrollHeight;
        panel.style.height = "0px";
        requestAnimationFrame(() => {
          panel.style.height = target + "px";
        });
        panel.addEventListener(
          "transitionend",
          () => {
            panel.style.height = "";
          },
          { once: true }
        );
      }
    });
  });
</script>

<style>
  .direttivo__panel {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: no-preference) {
    .direttivo__panel {
      transition: height 0.28s ease;
    }
  }
</style>
