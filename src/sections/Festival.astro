---
import { festival } from "../data/content";
import SectionHeading from "../components/SectionHeading.astro";
import StarIcon from "../components/StarIcon.astro";
---

<section id="festival" class="festival">
  <div class="festival__inner container">
    <SectionHeading eyebrow="Chi siamo" title={festival.heading} />

    <div class="festival__grid">
      <div class="festival__text reveal-up">
        {festival.paragraphs.map((p) => <p>{p}</p>)}
        <blockquote>
          {festival.highlight}
        </blockquote>
      </div>

      <div class="festival__awards reveal-up">
        <h3>{festival.awardsHeading}</h3>
        {
          festival.awards.map((award) => (
            <div class="festival__award-card">
              <img
                class="festival__award-image"
                src={award.name.includes("Rossella") ? "/images/rosella.jpg" : "/images/logo-premio.jpg"}
                alt={award.name}
              />
              <div class="festival__award-title">
                <StarIcon size="1.25rem" />
                <span>{award.name}</span>
              </div>
              <p>{award.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .festival {
    position: relative;
    background-color: var(--color-paper);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .festival {
      padding-block: 8rem;
    }
  }

  .festival__inner {
    max-width: 72rem;
  }

  .festival__grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .festival__grid {
      grid-template-columns: 1.3fr 1fr;
    }
  }

  .festival__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .festival__text p {
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-ink), 0.75);
  }

  @media (min-width: 640px) {
    .festival__text p {
      font-size: 1.125rem;
    }
  }

  .festival__text blockquote {
    margin-top: 1rem;
    border-left: 4px solid var(--color-sky-500);
    padding-left: 1.25rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.625;
    color: var(--color-ink);
  }

  @media (min-width: 640px) {
    .festival__text blockquote {
      font-size: 1.5rem;
    }
  }

  .festival__awards {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .festival__awards h3 {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .festival__awards h3 {
      font-size: 1.7rem;
    }
  }

  .festival__award-card {
    border-radius: 1rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    padding: 1.5rem;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
    transition: box-shadow 0.2s;
  }

  .festival__award-card:hover {
    box-shadow: 0 10px 15px rgba(var(--rgb-black), 0.1);
  }

  .festival__award-image {
    margin-bottom: 1rem;
    height: 4rem;
    width: 4rem;
    border-radius: 0.75rem;
    object-fit: cover;
  }

  .festival__award-title {
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-sky-500);
  }

  .festival__award-title span {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-primary-600);
  }

  .festival__award-card p {
    font-size: 0.875rem;
    line-height: 1.625;
    color: rgba(var(--rgb-ink), 0.7);
  }
</style>
