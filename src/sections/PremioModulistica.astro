---
import { premioModulistica } from "../data/premio-content";
import SectionHeading from "../components/SectionHeading.astro";

const downloadIcon =
  "M352 96C352 78.3 337.7 64 320 64C302.3 64 288 78.3 288 96L288 306.7L246.6 265.3C234.1 252.8 213.8 252.8 201.3 265.3C188.8 277.8 188.8 298.1 201.3 310.6L297.3 406.6C309.8 419.1 330.1 419.1 342.6 406.6L438.6 310.6C451.1 298.1 451.1 277.8 438.6 265.3C426.1 252.8 405.8 252.8 393.3 265.3L352 306.7L352 96zM160 384C124.7 384 96 412.7 96 448L96 480C96 515.3 124.7 544 160 544L480 544C515.3 544 544 515.3 544 480L544 448C544 412.7 515.3 384 480 384L433.1 384L376.5 440.6C345.3 471.8 294.6 471.8 263.4 440.6L206.9 384L160 384zM464 440C477.3 440 488 450.7 488 464C488 477.3 477.3 488 464 488C450.7 488 440 477.3 440 464C440 450.7 450.7 440 464 440z";
---

<section id="modulistica" class="premio-modulistica">
  <div class="premio-modulistica__inner container">
    <SectionHeading title={premioModulistica.heading} />

    <div class="premio-modulistica__grid">
      {
        premioModulistica.documenti.map((doc) => (
          <a
            href={doc.href}
            target="_blank"
            rel="noopener noreferrer"
            class="premio-modulistica__card reveal-up"
          >
            <div class="premio-modulistica__icon icon-plain">
              <svg viewBox="0 0 640 640" fill="currentColor">
                <path d={downloadIcon} />
              </svg>
            </div>
            <h3>{doc.label}</h3>
            <p>{doc.description}</p>
            <span class="premio-modulistica__cta">Scarica PDF →</span>
          </a>
        ))
      }
    </div>

    <p class="premio-modulistica__contact reveal-up">
      Candidature e domande: <a href="mailto:donnefralestelle@gmail.com">donnefralestelle@gmail.com</a>
    </p>
  </div>
</section>

<style>
  .premio-modulistica {
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .premio-modulistica {
      padding-block: 8rem;
    }
  }

  .premio-modulistica__inner {
    max-width: 72rem;
  }

  .premio-modulistica__grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .premio-modulistica__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .premio-modulistica__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .premio-modulistica__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
    border-radius: 1.5rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    padding: 1.75rem;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
    transition: all 0.3s;
  }

  .premio-modulistica__card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 25px rgba(var(--rgb-black), 0.1);
    border-color: rgba(var(--rgb-sky-400), 0.4);
  }

  .premio-modulistica__icon {
    color: var(--color-primary-600);
  }

  .premio-modulistica__card h3 {
    font-family: var(--font-primary);
    font-size: 1.125rem;
    line-height: 1.3;
    color: var(--color-primary-600);
  }

  .premio-modulistica__card p {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(var(--rgb-primary-600), 0.65);
  }

  .premio-modulistica__cta {
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-sky-600);
  }

  .premio-modulistica__contact {
    margin-top: 3rem;
    text-align: center;
    font-size: 0.9375rem;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  .premio-modulistica__contact a {
    font-weight: 600;
    color: var(--color-primary-600);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
