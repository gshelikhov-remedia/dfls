---
import { Image } from "astro:assets";
import { premioHero } from "../data/premio-content";
import Button from "../components/Button.astro";
import StarIcon from "../components/StarIcon.astro";
import rosellaImage from "../assets/rosella.jpg";
import rosellaAvatar from "../assets/rosella.png";
---

<section id="top" class="premio-hero">
  <div class="premio-hero__bg">
    <Image
      src={rosellaImage}
      alt=""
      class="premio-hero__bg-image"
      widths={[640, 960, 1440]}
      sizes="100vw"
      quality={80}
      format="webp"
    />
    <div class="premio-hero__gradient premio-hero__gradient--vertical"></div>
    <div class="premio-hero__gradient premio-hero__gradient--horizontal"></div>
  </div>
  <div class="starfield"></div>
  <div class="premio-hero__glow" aria-hidden="true"></div>

  <div class="premio-hero__inner container">
    <img
  src={rosellaAvatar.src}
  alt="Rossella"
  class="premio-hero__avatar"
/>
    <span id="premio-eyebrow" class="premio-hero__eyebrow">
      <StarIcon size="0.875rem" />
      {premioHero.eyebrow}
    </span>

    <h1 id="premio-title" class="premio-hero__title text-balance">
      {premioHero.titleLine1}<br />
      <em>{premioHero.titleLine2}</em>
    </h1>

    <p id="premio-tagline" class="premio-hero__tagline text-balance">
      {premioHero.tagline}
    </p>

    <div id="premio-meta" class="premio-hero__meta">
      <span class="premio-hero__deadline-label">{premioHero.deadlineLabel}</span>
      <span class="premio-hero__deadline">{premioHero.deadline}</span>
    </div>

    <div id="premio-ctas" class="premio-hero__ctas">
      <Button href={premioHero.ctaPrimary.href} variant="primary">{premioHero.ctaPrimary.label}</Button>
      <Button href={premioHero.ctaSecondary.href} variant="outline">{premioHero.ctaSecondary.label}</Button>
    </div>
  </div>
</section>

<style>
  .premio-hero {
    position: relative;
    overflow: hidden;
    display: flex;
    min-height: 100vh;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--color-ink);
    padding-top: 9rem;
    padding-bottom: 2rem;
  }

  @media (min-width: 640px) {
    .premio-hero {
      padding-top: 10rem;
    }
  }

  .premio-hero__bg {
    position: absolute;
    inset: 0;
  }

  .premio-hero__bg-image {
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  .premio-hero__gradient {
    position: absolute;
    inset: 0;
  }

  .premio-hero__gradient--vertical {
    background: linear-gradient(
      to bottom,
      rgba(var(--rgb-ink), 0.55),
      rgba(var(--rgb-ink), 0.75),
      var(--color-ink)
    );
  }

  .premio-hero__gradient--horizontal {
    background: linear-gradient(
      to right,
      rgba(var(--rgb-ink), 0.75),
      transparent,
      rgba(var(--rgb-ink), 0.75)
    );
  }

  .premio-hero__glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 50% at 50% 20%, rgba(var(--rgb-sky-400), 0.18), transparent 70%);
    pointer-events: none;
  }

  .premio-hero__inner {
    position: relative;
    display: flex;
    max-width: 56rem;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }


  .premio-hero__avatar {

  height: 4rem;
  width: 4rem;
  border-radius: 99rem;
  object-fit: cover;
  border: 2px solid rgba(var(--rgb-sky-300), 0.1);
}

  .premio-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-sky-300);
  }

  .premio-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: white;
  }

  .premio-hero__title em {
    font-style: italic;
    color: var(--color-sky-300);
  }

  .premio-hero__tagline {
    max-width: 38rem;
    font-size: 1.0625rem;
    line-height: 1.625;
    color: rgba(var(--rgb-white), 0.75);
  }

  @media (min-width: 640px) {
    .premio-hero__tagline {
      font-size: 1.25rem;
    }
  }

  .premio-hero__meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
    border-radius: 1rem;
    border: 1px solid rgba(var(--rgb-sky-300), 0.1);
    padding: 2rem;
  }

  .premio-hero__deadline-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(var(--rgb-white), 0.55);
  }

  .premio-hero__deadline {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.01em;
    color: var(--color-sky-300);
  }

  .premio-hero__ctas {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
</style>
