---
import { programmeHeading, programmeDays } from "../data/content";
import SectionHeading from "../components/SectionHeading.astro";
import StarIcon from "../components/StarIcon.astro";
---

<section id="programma" class="programme">
  <div class="programme__inner container">
    <SectionHeading title={programmeHeading.title} />
    <p class="programme__tagline reveal-up text-balance">{programmeHeading.tagline}</p>

    <div data-programme-wrap class="programme-tabs reveal-up">
      <div class="programme-tabs__jump" data-day-jump role="tablist" aria-label="Seleziona giornata">
        {
          programmeDays.map((day, i) => (
            <button
              type="button"
              data-day-goto={i}
              class={`programme-tabs__jump-btn ${i === 0 ? "is-active" : ""}`}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
            >
              <span class="programme-tabs__jump-date">{day.tabLabel}</span>
            </button>
          ))
        }
      </div>

      <div class="programme-tabs__panels">
        {
          programmeDays.map((day, i) => (
            <div
              data-day-panel
              class={`programme-day ${i === 0 ? "is-active" : ""}`}
              role="tabpanel"
              aria-hidden={i === 0 ? "false" : "true"}
            >
              <p class="programme-day__venue">{day.venueLabel}</p>

              {day.blocks.map((block) => (
                <div class="programme-block">
                  {block.heading && <h3 class="programme-block__heading">{block.heading}</h3>}

                  <div class="programme-schedule">
                    {block.sessions.map((session) =>
                      session.interlude ? (
                        <div class="programme-row programme-row--interlude">
                          <span class="programme-row__time">{session.time}</span>
                          <div class="programme-row__interlude-body">
                            <span class="programme-row__title">{session.title}</span>
                            {session.moderator && <span class="programme-row__moderator">{session.moderator}</span>}
                            {session.note && <span class="programme-row__note">{session.note}</span>}
                          </div>
                        </div>
                      ) : (
                        <details class="programme-row programme-row--session">
                          <summary class="programme-row__summary">
                            <span class="programme-row__time">{session.time}</span>
                            <span class="programme-row__title">{session.title}</span>
                            <svg
                              class="programme-row__chevron"
                              fill="none"
                              viewBox="0 0 24 24"
                              stroke="currentColor"
                              stroke-width="2"
                            >
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                            </svg>
                          </summary>
                          <div class="programme-row__body">
                            {session.moderator && <p class="programme-row__moderator">{session.moderator}</p>}
                            {session.description?.map((p) => <p class="programme-row__desc">{p}</p>)}
                            {session.speakers && (
                              <ul class="programme-row__speakers">
                                {session.speakers.map((s) => (
                                  <li class="programme-row__speaker">
                                    <StarIcon size="0.65rem" class="programme-row__speaker-icon" />
                                    <span>{s}</span>
                                  </li>
                                ))}
                              </ul>
                            )}
                            {session.note && <p class="programme-row__note">{session.note}</p>}
                          </div>
                        </details>
                      )
                    )}
                  </div>
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .programme {
    position: relative;
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .programme {
      padding-block: 8rem;
    }
  }

  .programme__inner {
    max-width: 72rem;
  }

  .programme__tagline {
    margin-top: 1rem;
    text-align: center;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .programme__tagline {
      font-size: 1.375rem;
    }
  }

  .programme__lead {
    max-width: 42rem;
    margin: 1.25rem auto 0;
    text-align: center;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(var(--rgb-primary-600), 0.7);
  }

  @media (min-width: 640px) {
    .programme__lead {
      font-size: 1rem;
    }
  }

  /* ---------- Tab switcher (echoes .editions-slider__jump) ---------- */

  .programme-tabs {
    margin-top: 3rem;
  }

  .programme-tabs__jump {
    display: flex;
    align-items: stretch;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .programme-tabs__jump-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 8rem;
    border-radius: 9999px;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    padding: 0.7rem 1.5rem;
    transition: all 0.25s;
  }

  .programme-tabs__jump-btn:hover {
    border-color: var(--color-sky-400);
  }

  .programme-tabs__jump-btn.is-active {
    background-color: var(--color-sky-400);
    border-color: var(--color-sky-400);
  }

  .programme-tabs__jump-date {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-primary-600);
  }

  .programme-day {
    display: none;
  }

  .programme-day.is-active {
    display: block;
  }

  .programme-day__venue {
    margin-bottom: 2rem;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-sky-600);
  }

  .programme-block + .programme-block {
    margin-top: 2.5rem;
  }

  .programme-block__heading {
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--color-primary-600);
  }

  /* ---------- Schedule rows (echoes .comparison-table) ---------- */

  .programme-schedule {
    overflow: hidden;
    border-radius: 1rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
  }

  .programme-row {
    display: block;
    border-bottom: 1px solid var(--color-primary-100);
  }

  .programme-row:last-child {
    border-bottom: none;
  }

  .programme-row:nth-child(even) {
    background-color: rgba(var(--rgb-mist), 0.5);
  }

  .programme-row--interlude {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
  }

  .programme-row__interlude-body {
    display: flex;
    flex: 1 1 auto;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.75rem;
  }

  .programme-row--interlude .programme-row__title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.8125rem;
    font-style: italic;
    color: rgba(var(--rgb-primary-600), 0.55);
  }

  .programme-row__summary {
    display: flex;
    cursor: pointer;
    list-style: none;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .programme-row__summary::-webkit-details-marker {
    display: none;
  }

  .programme-row__time {
    flex-shrink: 0;
    width: 3.25rem;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-sky-600);
  }

  .programme-row--interlude .programme-row__time {
    padding-top: 0.05rem;
  }

  .programme-row__title {
    flex: 1 1 auto;
    font-family: var(--font-primary);
    font-weight: 600;
    font-size: 0.9375rem;
    line-height: 1.4;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .programme-row__title {
      font-size: 1rem;
    }
  }

  .programme-row__chevron {
    flex-shrink: 0;
    height: 1.125rem;
    width: 1.125rem;
    color: var(--color-sky-500);
    transition: transform 0.2s;
  }

  .programme-row--session[open] .programme-row__chevron {
    transform: rotate(180deg);
  }

  .programme-row__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0 1.25rem 1.5rem calc(3.25rem + 1.25rem + 1rem);
  }

  .programme-row__moderator {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-sky-600);
  }

  .programme-row--interlude .programme-row__moderator,
  .programme-row--interlude .programme-row__note {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-sky-600);
    font-style: normal;
  }

  .programme-row__desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  .programme-row__speakers {
    display: grid;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .programme-row__speakers {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem 1.25rem;
    }
  }

  .programme-row__speaker {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: rgba(var(--rgb-primary-600), 0.8);
  }

  .programme-row__speaker-icon {
    flex-shrink: 0;
    margin-top: 0.4rem;
    color: var(--color-sky-500);
  }

  .programme-row__note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9375rem;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  /* Narrow screens: drop the hanging indent, stack time above content */
  @media (max-width: 480px) {
    .programme-row__summary {
      align-items: flex-start;
    }

    .programme-row__body {
      padding-left: 1.25rem;
    }
  }

</style>

<script>
  import { gsap } from "gsap";

  function initProgrammeTabs() {
    const wrap = document.querySelector<HTMLElement>("[data-programme-wrap]");
    if (!wrap) return;

    const btns = Array.from(wrap.querySelectorAll<HTMLButtonElement>("[data-day-goto]"));
    const panels = Array.from(wrap.querySelectorAll<HTMLElement>("[data-day-panel]"));
    if (!btns.length || !panels.length) return;

    let active = panels.findIndex((p) => p.classList.contains("is-active"));
    if (active < 0) active = 0;

    let isAnimating = false;

    function setActiveButtons(index: number) {
      btns.forEach((btn, i) => {
        btn.classList.toggle("is-active", i === index);
        btn.setAttribute("aria-selected", String(i === index));
      });
    }

    function goTo(index: number) {
      if (index === active || isAnimating) return;
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const outgoing = panels[active];
      const incoming = panels[index];
      isAnimating = true;
      setActiveButtons(index);

      function swap() {
        outgoing.classList.remove("is-active");
        outgoing.setAttribute("aria-hidden", "true");
        incoming.classList.add("is-active");
        incoming.setAttribute("aria-hidden", "false");
        active = index;
      }

      if (reduceMotion) {
        swap();
        isAnimating = false;
        return;
      }

      gsap.to(outgoing, {
        autoAlpha: 0,
        duration: 0.2,
        ease: "power1.in",
        onComplete: () => {
          swap();
          gsap.fromTo(
            incoming,
            { autoAlpha: 0, y: 10 },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.35,
              ease: "power2.out",
              onComplete: () => {
                isAnimating = false;
              },
            }
          );
        },
      });
    }

    btns.forEach((btn, i) => {
      btn.addEventListener("click", () => goTo(i));
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    initProgrammeTabs();
  });
</script>
