---
import { premioModalita } from "../data/premio-content";
import SectionHeading from "../components/SectionHeading.astro";
---

<section id="modalita" class="premio-modalita">
  <div class="premio-modalita__inner container">
    <SectionHeading title={premioModalita.heading} />
    <p class="premio-modalita__intro reveal-up text-balance">{premioModalita.intro}</p>

    <div class="premio-modalita__rows">
      {
        premioModalita.steps.map((step, i) => (
          <article class="premio-modalita__row reveal-up">
            <div class="premio-modalita__marker">
              <span class="premio-modalita__number">{String(i + 1).padStart(2, "0")}</span>
            </div>
            <div class="premio-modalita__body">
              <h3>{step.title}</h3>
              <p class="premio-modalita__text">{step.text}</p>
              {step.list && (
                <ul>
                  {step.list.map((item) => (
                    <li>
                      <svg class="premio-modalita__check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
              {step.note && <p class="premio-modalita__note">{step.note}</p>}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .premio-modalita {
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .premio-modalita {
      padding-block: 8rem;
    }
  }

  .premio-modalita__inner {
    max-width: 72rem;
  }

  .premio-modalita__intro {
    margin: 1.25rem auto 0;
    max-width: 42rem;
    text-align: center;
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (min-width: 640px) {
    .premio-modalita__intro {
      font-size: 1.125rem;
    }
  }

  .premio-modalita__rows {
    margin-top: 3.5rem;
    border-top: 1px solid var(--color-primary-100);
  }

  .premio-modalita__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding-block: 2rem;
    border-bottom: 1px solid var(--color-primary-100);
  }

  @media (min-width: 768px) {
    .premio-modalita__row {
      grid-template-columns: 12rem 1fr;
      gap: 2.5rem;
      padding-block: 2.75rem;
      align-items: start;
    }
  }

  .premio-modalita__marker {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .premio-modalita__number {
    font-family: var(--font-display);
    font-size: 2.75rem;
    font-weight: 300;
    line-height: 1;
    color: var(--color-sky-500);
  }

  @media (min-width: 768px) {
    .premio-modalita__number {
      font-size: 3.25rem;
    }
  }

  .premio-modalita__body {
    max-width: 46rem;
  }

  .premio-modalita__body h3 {
    font-family: var(--font-primary);
    font-size: 1.375rem;
    line-height: 1.2;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .premio-modalita__body h3 {
      font-size: 1.625rem;
    }
  }

  .premio-modalita__text {
    margin-top: 0.75rem;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(var(--rgb-primary-600), 0.78);
  }

  .premio-modalita__body ul {
    margin-top: 1.125rem;
    display: grid;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .premio-modalita__body ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem 2rem;
    }
  }

  .premio-modalita__body li {
    display: flex;
    gap: 0.625rem;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .premio-modalita__body li span {
    color: rgba(var(--rgb-primary-600), 0.78);
  }

  .premio-modalita__check {
    margin-top: 0.1875rem;
    height: 1rem;
    width: 1rem;
    flex-shrink: 0;
    color: var(--color-sky-500);
  }

  .premio-modalita__note {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-primary-100);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--color-sky-600);
  }
</style>
