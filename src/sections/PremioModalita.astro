---
import { premioModalita } from "../data/premio-content";
import SectionHeading from "../components/SectionHeading.astro";
---

<section id="modalita" class="premio-modalita">
  <div class="premio-modalita__inner container">
    <SectionHeading title={premioModalita.heading} />
    <p class="premio-modalita__intro reveal-up text-balance">{premioModalita.intro}</p>

    <div class="premio-modalita__grid">
      {
        premioModalita.steps.map((step, i) => (
          <div class="premio-modalita__card reveal-up">
            <span class="premio-modalita__number">{String(i + 1).padStart(2, "0")}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
            {step.list && (
              <ul>
                {step.list.map((item) => (
                  <li>
                    <svg class="premio-modalita__check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
            {step.note && <p class="premio-modalita__note">{step.note}</p>}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .premio-modalita {
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .premio-modalita {
      padding-block: 8rem;
    }
  }

  .premio-modalita__inner {
    max-width: 72rem;
  }

  .premio-modalita__intro {
    margin: 1.25rem auto 0;
    max-width: 42rem;
    text-align: center;
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (min-width: 640px) {
    .premio-modalita__intro {
      font-size: 1.125rem;
    }
  }

  .premio-modalita__grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .premio-modalita__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .premio-modalita__card {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 1.5rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    padding: 1.75rem;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
    transition: box-shadow 0.2s;
  }

  @media (min-width: 640px) {
    .premio-modalita__card {
      min-height: 22rem;
    }
  }

  .premio-modalita__card:hover {
    box-shadow: 0 20px 25px rgba(var(--rgb-black), 0.1);
  }

  .premio-modalita__number {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: var(--color-sky-500);
  }

  .premio-modalita__card h3 {
    margin-top: 0.75rem;
    font-family: var(--font-primary);
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .premio-modalita__card h3 {
      font-size: 1.7rem;
    }
  }

  .premio-modalita__card p {
    margin-top: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  .premio-modalita__card ul {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .premio-modalita__card li {
    display: flex;
    gap: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .premio-modalita__card li span {
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  .premio-modalita__check {
    margin-top: 0.125rem;
    height: 1rem;
    width: 1rem;
    flex-shrink: 0;
    color: var(--color-sky-500);
  }

  .premio-modalita__note {
    margin-top: 1rem;
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--color-sky-600);
  }
</style>
