---
import { premioScopo } from "../data/premio-content";
import SectionHeading from "../components/SectionHeading.astro";
---

<section id="premio" class="premio-scopo">
  <div class="premio-scopo__inner container">
    <SectionHeading title={premioScopo.heading} />

    <div class="premio-scopo__grid">
      <div class="premio-scopo__text reveal-up">
        {premioScopo.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <div class="premio-scopo__card reveal-up">
        <h3>{premioScopo.requisitiHeading}</h3>
        <ul>
          {
            premioScopo.requisiti.map((item) => (
              <li>
                <svg class="premio-scopo__check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .premio-scopo {
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .premio-scopo {
      padding-block: 8rem;
    }
  }

  .premio-scopo__inner {
    max-width: 72rem;
  }

  .premio-scopo__grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .premio-scopo__grid {
      grid-template-columns: 1.3fr 1fr;
    }
  }

  .premio-scopo__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .premio-scopo__text p {
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (min-width: 640px) {
    .premio-scopo__text p {
      font-size: 1.0625rem;
    }
  }

  .premio-scopo__card {
    align-self: start;
    border-radius: 1.5rem;
    border: 1px solid var(--color-primary-100);
    background-color: white;
    padding: 1.75rem;
    box-shadow: 0 1px 2px rgba(var(--rgb-black), 0.05);
  }

  .premio-scopo__card h3 {
    font-family: var(--font-primary);
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--color-primary-600);
  }

  .premio-scopo__card ul {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .premio-scopo__card li {
    display: flex;
    gap: 0.625rem;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .premio-scopo__card li span {
    color: rgba(var(--rgb-primary-600), 0.8);
  }

  .premio-scopo__check {
    margin-top: 0.125rem;
    height: 1.125rem;
    width: 1.125rem;
    flex-shrink: 0;
    color: var(--color-sky-500);
  }
</style>
