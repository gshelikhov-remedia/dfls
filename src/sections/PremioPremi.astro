---
import { premioPremi } from "../data/premio-content";
import SectionHeading from "../components/SectionHeading.astro";
import StarIcon from "../components/StarIcon.astro";

// Filled icons (640x640 viewBox), same convention as WhySponsor's "fill" type.
// Trophy for the physical award, globe for the ESA travel prize.
