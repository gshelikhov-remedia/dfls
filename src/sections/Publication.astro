---
import { publication } from "../data/content";
import Button from "../components/Button.astro";
---

<section class="publication">
  <div class="starfield"></div>
  <div class="publication__inner container">
    <div class="publication__text reveal-up">
      <p class="publication__quote text-balance">
        {publication.quote}
      </p>
      <p class="publication__quote-secondary">{publication.quoteSecondary}</p>
    </div>

    <div class="publication__card reveal-up">
      <div class="publication__book">
        <img src={publication.bookImage} alt={publication.bookAlt} loading="lazy" />
      </div>

      <div class="publication__details">
        <div class="publication__heading">
          <span class="publication__subtitle">Acquista il libro</span>
          <h3 class="publication__name">Donne fra le stelle</h3>
        </div>

        <p class="publication__payoff">{publication.payoff}</p>

        <div class="publication__qr">
          <img src={publication.qrCode} alt={publication.qrAlt} loading="lazy" width="120" height="120" />
        </div>

        <div class="publication__cta">
          <Button href={publication.springerUrl} variant="primary">
            {publication.ctaLabel}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .publication {
    position: relative;
    overflow: hidden;
    background-color: var(--color-ink);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .publication {
      padding-block: 7rem;
    }
  }

  .publication__inner {
    position: relative;
    max-width: 64rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    text-align: center;
  }

  .publication__text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .publication__quote {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    line-height: 1.3;
    color: white;
  }

  @media (min-width: 640px) {
    .publication__quote {
      font-size: 2.25rem;
    }
  }

  .publication__quote-secondary {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-sky-300);
  }

  @media (min-width: 640px) {
    .publication__quote-secondary {
      font-size: 1.5rem;
    }
  }

  .publication__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: 48rem;
    padding: 2rem;
    border-radius: 1.5rem;
    background: rgba(var(--rgb-white), 0.04);
    border: 1px solid rgba(var(--rgb-white), 0.1);
    backdrop-filter: blur(6px);
  }

  @media (min-width: 768px) {
    .publication__card {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 3rem;
      padding: 3rem;
    }
  }

  .publication__book {
    flex-shrink: 0;
    width: 100%;
    max-width: 18rem;
    overflow: hidden;
    border-radius: 0.75rem;
    box-shadow: 0 25px 50px rgba(var(--rgb-black), 0.4);
  }

  @media (min-width: 768px) {
    .publication__book {
      max-width: 14rem;
    }
  }

  .publication__book img {
    display: block;
    width: 100%;
    height: auto;
  }

  .publication__details {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .publication__details {
      align-items: flex-start;
    }
  }

  .publication__heading {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .publication__subtitle {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-sky-300);
  }

  .publication__name {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    line-height: 1.2;
    color: white;
  }

  @media (min-width: 640px) {
    .publication__name {
      font-size: 1.7rem;
    }
  }

  .publication__payoff {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: white;
    line-height: 1.5;
  }

  .publication__qr {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    background: white;
    border-radius: 0.75rem;
    line-height: 0;
  }

  .publication__qr img {
    width: 100px;
    height: 100px;
    display: block;
  }

  .publication__cta {
    width: 100%;
  }

  .publication__cta :global(.btn) {
    width: 100%;
  }

  @media (min-width: 480px) {
    .publication__cta,
    .publication__cta :global(.btn) {
      width: auto;
    }
  }
</style>
