---
import { venue } from "../data/content";
import SectionHeading from "../components/SectionHeading.astro";
import Gallery from "../components/Gallery.astro";
---

<section id="sede" class="venue">
  <div class="venue__inner container">
    <SectionHeading eyebrow={venue.heading} title={venue.name} />

    <div class="venue__layout">
      <div class="venue__text reveal-up">
        <p>{venue.paragraphs[0]}</p>
        <p>{venue.paragraphs[1]}</p>
        <blockquote class="venue__callout">{venue.highlight}</blockquote>
        <p>{venue.paragraphs[2]}</p>
        <p>{venue.paragraphs[3]}</p>
      </div>

      <div class="venue__gallery">
        <Gallery />
      </div>
    </div>
  </div>
</section>

<style>
  .venue {
    position: relative;
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .venue {
      padding-block: 8rem;
    }
  }

  .venue__inner {
    max-width: 72rem;
  }

  .venue__layout {
    margin-top: 3.5rem;
    display: grid;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .venue__layout {
      grid-template-columns: 1.1fr 1fr;
      align-items: start;
      gap: 3.5rem;
    }
  }

  .venue__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .venue__text p {
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.75);
  }

  @media (min-width: 640px) {
    .venue__text p {
      font-size: 1.125rem;
    }
  }

  .venue__callout {
    margin-block: 0.5rem;
    border-left: 4px solid var(--color-sky-500);
    padding-left: 1.25rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--color-primary-600);
  }

  @media (min-width: 640px) {
    .venue__callout {
      font-size: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .venue__gallery {
      position: sticky;
      top: 6rem;
    }
  }
</style>
