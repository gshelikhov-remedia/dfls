---
import { galleryHeading } from "../data/content";
import SectionHeading from "../components/SectionHeading.astro";
import PhotoGallery from "../components/PhotoGallery.astro";
---

<section id="galleria" class="photo-section">
  <div class="photo-section__inner container">
    <SectionHeading eyebrow={galleryHeading.eyebrow} title={galleryHeading.title} />
    <p class="photo-section__lead reveal-up text-balance">{galleryHeading.intro}</p>

    <div class="photo-section__gallery">
      <PhotoGallery />
    </div>
  </div>
</section>

<style>
  .photo-section {
    position: relative;
    background-color: var(--color-mist);
    padding-block: 6rem;
  }

  @media (min-width: 640px) {
    .photo-section {
      padding-block: 8rem;
    }
  }

  .photo-section__inner {
    max-width: 80rem;
  }

  .photo-section__lead {
    max-width: 42rem;
    margin: 1.25rem auto 0;
    text-align: center;
    font-size: 1rem;
    line-height: 1.625;
    color: rgba(var(--rgb-primary-600), 0.7);
  }

  @media (min-width: 640px) {
    .photo-section__lead {
      font-size: 1.125rem;
    }
  }

  .photo-section__gallery {
    margin-top: 3.5rem;
  }
</style>
