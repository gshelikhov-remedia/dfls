---
import { hero } from "../data/content";
import Button from "../components/Button.astro";
import LogoMarquee from "../components/LogoMarquee.astro";
---

<section id="top" class="hero">
  <div class="hero__bg">
    <img
      src="/images/hero-bg.webp"
      alt=""
      class="hero__poster"
      fetchpriority="high"
    />
    <video
      data-src="/videos/bg-video-10sec.mp4"
      class="hero__video"
      loop
      muted
      playsinline
      preload="none"
    ></video>
    <div class="hero__gradient hero__gradient--vertical"></div>
    <div class="hero__gradient hero__gradient--horizontal"></div>
  </div>

  <div class="hero__content container">
    <p id="hero-eyebrow" class="hero__kicker">
      {hero.eyebrow}
    </p>

    <h1 id="hero-title" class="hero__title text-balance">
      <span class="hero__title-main">{hero.title}</span>
    </h1>

    <p id="hero-tagline" class="hero__tagline text-balance">
      "{hero.tagline}"
    </p>

    <p id="hero-meta" class="hero__meta">
      {hero.location} · {hero.venue}
    </p>

    <div id="hero-ctas" class="hero__ctas">
      <Button href={hero.ctaSecondary.href} variant="primary">{hero.ctaSecondary.label}</Button>
    </div>
  </div>

  <div class="hero__marquee-wrap container">
    <LogoMarquee />
  </div>
</section>

<script>
  // Attach the hero background video during idle time (off the critical
  // path). The static poster <img> is the LCP and stays visible; the video
  // fades in over it once frames are actually rendering. Skip entirely on
  // small screens, reduced-motion, Save-Data, or slow connections.
  const video = document.querySelector<HTMLVideoElement>(".hero__video");
  if (video) {
    const conn = (navigator as any).connection;
    const slowConnection =
      conn && conn.effectiveType && !String(conn.effectiveType).includes("4g");
    const skip =
      window.matchMedia("(max-width: 640px)").matches ||
      window.matchMedia("(prefers-reduced-motion: reduce)").matches ||
      (conn && conn.saveData) ||
      slowConnection;

    const attach = () => {
      const src = video.getAttribute("data-src");
      if (!src || video.src) return;

      const start = () => {
        video.play().catch(() => {});
      };

      // Fade over the poster only when frames are actually painting.
      video.addEventListener("playing", () => {
        video.classList.add("is-playing");
      });

      // Start as soon as the browser can render frames and keep buffering in
      // the background. (The old canplaythrough + loadeddata-timeout combo
      // started Firefox after the *first frame*, outrunning the buffer.)
      video.addEventListener("canplay", start, { once: true });

      // Stall recovery: Firefox suspends media downloads aggressively, so if
      // playback outruns the buffer, resume when it catches up instead of
      // freezing on the last decoded frame.
      video.addEventListener("waiting", () => {
        video.classList.remove("is-playing");
        video.addEventListener("canplay", start, { once: true });
      });

      video.preload = "auto";
      video.src = src;
      video.load();
    };

    if (!skip) {
      const schedule = () =>
        window.requestIdleCallback
          ? window.requestIdleCallback(attach)
          : setTimeout(attach, 100);
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", schedule, { once: true });
      } else {
        schedule();
      }
    }
  }
</script>

<style>
  .hero {
    position: relative;
    display: flex;
    min-height: 100vh;
    flex-direction: column;
    overflow: hidden;
    background-color: var(--color-ink);
    padding-bottom: 2rem;
    padding-top: 9rem;
  }

  @media (min-width: 640px) {
    .hero {
      padding-top: 10rem;
    }
  }

  .hero__bg {
    position: absolute;
    inset: 0;
  }

  .hero__poster {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.9;
  }

  .hero__video {
    position: relative;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .hero__video.is-playing {
    opacity: 0.9;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
  }

  .hero__gradient--vertical {
    background: linear-gradient(
      to bottom,
      rgba(var(--rgb-ink), 0.2),
      rgba(var(--rgb-ink), 0.45),
      var(--color-ink)
    );
  }

  .hero__gradient--horizontal {
    background: linear-gradient(
      to right,
      rgba(var(--rgb-ink), 0.45),
      transparent,
      rgba(var(--rgb-ink), 0.45)
    );
  }

  .hero__content {
    position: relative;
    flex: 1;
    max-width: 64rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  /* Hero entrance: pure CSS so it starts at first paint. The previous
     gsap.from() version rendered the text visible, then hid it once the JS
     bundle arrived and animated it back in — a visible blink on cold cache.
     Delays mirror the old GSAP timeline. Reduced-motion is handled by the
     global override (durations forced to ~0). */
  @keyframes hero-enter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero__content > * {
    animation: hero-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  #hero-title { animation-delay: 0.25s; }
  #hero-tagline { animation-delay: 0.6s; }
  #hero-meta { animation-delay: 0.9s; }
  #hero-ctas { animation-delay: 1.15s; }

  .hero__kicker {
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--color-sky-300);
  }

  @media (min-width: 640px) {
    .hero__kicker {
      font-size: 1.875rem;
    }
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: var(--font-display);
    color: white;
  }

  .hero__title-main {
    margin-top: 0.25rem;
    font-size: 2.25rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.08;
    letter-spacing: 0.04em;
  }

  @media (min-width: 640px) {
    .hero__title-main {
      font-size: 3.75rem;
    }
  }

  @media (min-width: 768px) {
    .hero__title-main {
      font-size: 4.5rem;
    }
  }

  .hero__tagline {
    margin-top: 1.5rem;
    max-width: 42rem;
    font-family: var(--font-sans);
    font-size: 1.125rem;
    line-height: 1.625;
    color: rgba(var(--rgb-white), 0.85);
  }

  @media (min-width: 640px) {
    .hero__tagline {
      font-size: 1.25rem;
    }
  }

  .hero__meta {
    margin-top: 2rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(var(--rgb-sky-300), 0.9);
  }

  @media (min-width: 640px) {
    .hero__meta {
      font-size: 1rem;
    }
  }

  .hero__ctas {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .hero__ctas {
      flex-direction: row;
    }
  }

  .hero__marquee-wrap {
    position: relative;
    margin-top: 2rem;
    max-width: 72rem;
  }
</style>
