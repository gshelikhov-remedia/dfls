---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Hero from "../sections/Hero.astro";
import Festival from "../sections/Festival.astro";
import Programma from "../sections/Programma.astro";
import GallerySection from "../sections/GallerySection.astro";
import WhySponsor from "../sections/WhySponsor.astro";
import Sponsorship from "../sections/Sponsorship.astro";
import Sponsors from "../sections/Sponsors.astro";
import ComparisonSection from "../sections/ComparisonSection.astro";
import Venue from "../sections/Venue.astro";
import PreviousEditions from "../sections/PreviousEditions.astro";
import Publication from "../sections/Publication.astro";
import Contact from "../sections/Contact.astro";
---

<BaseLayout>
  <Navbar />
  <main>
    <Hero />
    <Festival />
    <Sponsors />
    <Programma />
    <GallerySection />
    <WhySponsor />
    <Sponsorship />
    <ComparisonSection />
    <Venue />
    <PreviousEditions />
    <Publication />
    <Contact />
  </main>
  <Footer />

<script>
    // Reveal-on-scroll (.reveal-up) is handled by an inline script in
    // BaseLayout so it never waits on this bundle. The hero entrance is pure
    // CSS in Hero.astro for the same reason: on cold cache this module used
    // to arrive late, hiding already-visible content and re-animating it.
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!reduceMotion) {
      // Below-the-fold card grids: GSAP is dynamically imported during idle
      // time so it stays entirely off the critical path.
      const initScrollAnimations = async () => {
      const [{ gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);
      gsap.registerPlugin(ScrollTrigger);
      // Vantaggi cards: one ScrollTrigger on the grid, cards stagger in
      // together instead of animating row by row.
      const vantaggiGrid = document.querySelector<HTMLElement>("#perche-sponsorizzare");
      if (vantaggiGrid) {
        const cards = gsap.utils.toArray<HTMLElement>(".vantaggi-card", vantaggiGrid);
        gsap.fromTo(
          cards,
          { y: 32, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.7,
            ease: "power3.out",
            stagger: { each: 0.1, from: "start" },
            scrollTrigger: {
              trigger: vantaggiGrid,
              start: "top 85%",
              toggleActions: "play none none reverse",
            },
          }
        );
      }
      // Sponsor logo grid: same one-ScrollTrigger stagger treatment as
      // the vantaggi cards, so the whole grid animates in together.
      const sponsorsGrid = document.querySelector<HTMLElement>("#sponsor");
      if (sponsorsGrid) {
        const cards = gsap.utils.toArray<HTMLElement>(".sponsor-card", sponsorsGrid);
        gsap.fromTo(
          cards,
          { y: 24, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.6,
            ease: "power3.out",
            stagger: { each: 0.04, from: "start" },
            scrollTrigger: {
              trigger: sponsorsGrid,
              start: "top 85%",
              toggleActions: "play none none reverse",
            },
          }
        );
      }
      };

      if (window.requestIdleCallback) {
        window.requestIdleCallback(initScrollAnimations);
      } else {
        setTimeout(initScrollAnimations, 200);
      }
    }
    // Under reduced motion nothing hides the cards in the first place —
    // their initial hidden state is applied by the GSAP fromTo above, which
    // never runs — so no else branch is needed.
  </script>
</BaseLayout>
